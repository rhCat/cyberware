{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberware.dev/spec/schemas/approval.schema.json",
  "title": "CWP approval message",
  "type": "object",
  "required": [
    "cwp",
    "type",
    "body",
    "sig"
  ],
  "additionalProperties": false,
  "properties": {
    "cwp": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "const": "approval"
    },
    "body": {
      "type": "object",
      "description": "a WebAuthn-locked consent for a destructive operation.",
      "required": [
        "operation",
        "key_id"
      ],
      "additionalProperties": false,
      "properties": {
        "operation": {
          "type": "string"
        },
        "key_id": {
          "type": "string",
          "pattern": "^ed25519:[0-9a-f]{16}$"
        },
        "challenge": {
          "type": "string"
        },
        "webauthn": {
          "type": "object"
        }
      }
    },
    "sig": {
      "type": "object",
      "required": [
        "keyid",
        "sig"
      ],
      "additionalProperties": false,
      "properties": {
        "keyid": {
          "type": "string",
          "pattern": "^ed25519:[0-9a-f]{16}$"
        },
        "sig": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
