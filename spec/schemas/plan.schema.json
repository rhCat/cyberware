{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberware.dev/spec/schemas/plan.schema.json",
  "title": "CWP plan message",
  "type": "object",
  "required": [
    "cwp",
    "type",
    "body",
    "sig"
  ],
  "additionalProperties": false,
  "properties": {
    "cwp": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "const": "plan"
    },
    "body": {
      "type": "object",
      "description": "govd -> agent; the value-free, code-free execution plan.",
      "required": [
        "sequence",
        "snippet_shas",
        "wrapper",
        "plan_sha"
      ],
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snippet_shas": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "wrapper": {
          "type": "string"
        },
        "plan_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "sig": {
      "type": "object",
      "required": [
        "keyid",
        "sig"
      ],
      "additionalProperties": false,
      "properties": {
        "keyid": {
          "type": "string",
          "pattern": "^ed25519:[0-9a-f]{16}$"
        },
        "sig": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
