{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberware.dev/spec/schemas/claim.schema.json",
  "title": "CWP claim message",
  "type": "object",
  "required": [
    "cwp",
    "type",
    "body",
    "sig"
  ],
  "additionalProperties": false,
  "properties": {
    "cwp": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "const": "claim"
    },
    "body": {
      "type": "object",
      "description": "agent -> govd; the agent's only output. MUST carry no commands or values.",
      "required": [
        "skill",
        "perk",
        "var_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "skill": {
          "type": "string"
        },
        "perk": {
          "type": "string"
        },
        "var_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approve": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sig": {
      "type": "object",
      "required": [
        "keyid",
        "sig"
      ],
      "additionalProperties": false,
      "properties": {
        "keyid": {
          "type": "string",
          "pattern": "^ed25519:[0-9a-f]{16}$"
        },
        "sig": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
