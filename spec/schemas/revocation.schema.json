{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberware.dev/spec/schemas/revocation.schema.json",
  "title": "CWP revocation message",
  "type": "object",
  "required": [
    "cwp",
    "type",
    "body",
    "sig"
  ],
  "additionalProperties": false,
  "properties": {
    "cwp": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "const": "revocation"
    },
    "body": {
      "type": "object",
      "description": "a feed entry withdrawing a key or a skill.",
      "required": [
        "target",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "target": {
          "enum": [
            "key",
            "skill"
          ]
        },
        "id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "sig": {
      "type": "object",
      "required": [
        "keyid",
        "sig"
      ],
      "additionalProperties": false,
      "properties": {
        "keyid": {
          "type": "string",
          "pattern": "^ed25519:[0-9a-f]{16}$"
        },
        "sig": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
